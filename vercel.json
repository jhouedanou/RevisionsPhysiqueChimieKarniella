{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "**/*.{html,css,js,json,png,jpg,jpeg,gif,svg,ico,webp,woff,woff2,ttf,eot}",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/sw\\.js",
            "headers": {
                "Cache-Control": "no-cache",
                "Service-Worker-Allowed": "/"
            },
            "dest": "/sw.js"
        },
        {
            "src": "/manifest\\.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/admin/?$",
            "dest": "/admin/login.html"
        },
        {
            "src": "/admin/(.*\\.(html|css|js|json|png|jpg|jpeg|gif|svg|ico))",
            "dest": "/admin/$1"
        },
        {
            "src": "/admin/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/(.+)\\.html$",
            "dest": "/$1.html"
        },
        {
            "src": "/(css|js|icons|public|data|pages-composantes)/(.*)",
            "dest": "/$1/$2"
        },
        {
            "src": "/([^/]+)/?$",
            "dest": "/$1.html"
        },
        {
            "src": "/$",
            "dest": "/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache"
                }
            ]
        }
    ]
}